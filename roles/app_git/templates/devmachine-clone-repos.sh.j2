#!/bin/bash
# Ansible-managed (roles/app_git). Runs at first user login via autostart
# to clone repositories from app_git_repos. Self-removes once every repo
# is present. Uses the gnome-keyring ssh-agent for the SSH passphrase
# (one askpass prompt the first time, then auto-unlocked at every login).

set -uo pipefail

LOG="${HOME}/.local/state/devmachine-clone-repos.log"
AUTOSTART="${HOME}/.config/autostart/devmachine-clone-repos.desktop"
SELF="$(readlink -f "$0")"
KEY="${HOME}/.ssh/{{ vm_owner_ssh_keyfilename }}"

mkdir -p "$(dirname "$LOG")"
exec >>"$LOG" 2>&1

echo
echo "=== $(date -Is) clone run starting (pid $$) ==="

if [ ! -r "$KEY" ]; then
    echo "missing key $KEY — aborting"
    exit 1
fi

# XFCE autostart launches us as a NON-login shell, so /etc/profile.d isn't
# sourced — SSH_AUTH_SOCK/SSH_ASKPASS would be unset and ssh-add would
# silently no-op (no agent, no GUI). Source the keyring init explicitly.
[ -r /etc/profile.d/app-keyring-ssh.sh ] && . /etc/profile.d/app-keyring-ssh.sh

# Fallback: if gnome-keyring's ssh-agent socket isn't up yet (pam_gnome_keyring
# can fail silently in xrdp sessions), spawn the daemon's ssh component
# ourselves. `eval` exports SSH_AUTH_SOCK/SSH_AGENT_PID into our env.
if [ -z "${SSH_AUTH_SOCK:-}" ] || [ ! -S "${SSH_AUTH_SOCK:-/nonexistent}" ]; then
    echo "no keyring ssh-agent socket — starting gnome-keyring-daemon" >&2
    eval "$(gnome-keyring-daemon --start --components=ssh 2>/dev/null)" || true
fi

if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    echo "WARNING: SSH_AUTH_SOCK still unset — ssh-add will not cache the passphrase" >&2
fi
echo "SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-<unset>}"
echo "SSH_ASKPASS=${SSH_ASKPASS:-<unset>}"
echo "DISPLAY=${DISPLAY:-<unset>}"

# Pre-load the key so we get one askpass prompt instead of one per repo.
ssh-add "$KEY" </dev/null || echo "ssh-add returned non-zero — check the values above" >&2

export GIT_SSH_COMMAND="ssh -i $KEY -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"

all_done=1
failed=()
{% for repo in app_git_repos %}
target={{ repo.target | quote }}
url={{ repo.repo | quote }}
if [ -d "$target/.git" ]; then
    echo "skip $target (already cloned)"
else
    mkdir -p "$(dirname "$target")"
    if git clone "$url" "$target"; then
        echo "cloned $url -> $target"
    else
        echo "FAILED $url -> $target"
        failed+=("$target")
        all_done=0
    fi
fi
{% endfor %}

if command -v notify-send >/dev/null 2>&1; then
    if [ "$all_done" -eq 1 ]; then
        notify-send "Devmachine" "All developer repositories cloned." || true
    else
        notify-send -u critical "Devmachine" \
            "Some repo clones failed: ${failed[*]} (see $LOG)" || true
    fi
fi

if [ "$all_done" -eq 1 ]; then
    echo "all repos present — removing autostart + self"
    rm -f "$AUTOSTART"
    rm -f "$SELF"
fi
