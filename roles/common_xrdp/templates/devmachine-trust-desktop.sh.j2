#!/bin/bash
# Ansible-managed (roles/common_xrdp). One-shot autostart that marks every
# .desktop launcher in ~/Desktop as trusted via gio metadata, so XFCE 4.18+
# stops prompting "the location is not trusted, run anyway?" on each icon.
# Removes itself + the autostart entry once done.

set -uo pipefail

LOG="${HOME}/.local/state/devmachine-trust-desktop.log"
AUTOSTART="${HOME}/.config/autostart/devmachine-trust-desktop.desktop"
SELF="$(readlink -f "$0")"

mkdir -p "$(dirname "$LOG")"
exec >>"$LOG" 2>&1

echo
echo "=== $(date -Is) trusting ~/Desktop launchers (pid $$) ==="

if ! command -v gio >/dev/null 2>&1; then
    echo "gio not on PATH; skipping (install glib2 if launchers stay flagged)" >&2
    exit 0
fi

shopt -s nullglob
for f in "$HOME/Desktop"/*.desktop; do
    if gio set "$f" metadata::trusted true; then
        echo "trusted $f"
    else
        echo "FAILED to trust $f" >&2
    fi
done
shopt -u nullglob

echo "all done — removing autostart + self"
rm -f "$AUTOSTART"
rm -f "$SELF"
