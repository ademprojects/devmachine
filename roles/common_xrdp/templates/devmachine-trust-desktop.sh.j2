#!/bin/bash
# Ansible-managed (roles/common_xrdp). One-shot autostart that marks every
# .desktop launcher in ~/Desktop as trusted, so XFCE 4.18+ stops prompting
# "Nicht vertrauenswürdiger Anwendungsstarter / the location is not trusted".
#
# XFCE 4.18+ pinned launcher trust to the file's content hash via the
# metadata::xfce-exe-checksum attribute — the trust becomes invalid the
# moment the .desktop content changes. metadata::trusted (the Nautilus
# attribute) alone is not honoured by xfdesktop. We set both so older
# XFCE versions keep working too.
#
# Removes itself + the autostart entry once done.

set -uo pipefail

LOG="${HOME}/.local/state/devmachine-trust-desktop.log"
AUTOSTART="${HOME}/.config/autostart/devmachine-trust-desktop.desktop"
SELF="$(readlink -f "$0")"

mkdir -p "$(dirname "$LOG")"
exec >>"$LOG" 2>&1

echo
echo "=== $(date -Is) trusting ~/Desktop launchers (pid $$) ==="

if ! command -v gio >/dev/null 2>&1; then
    echo "gio not on PATH; skipping (install glib2 if launchers stay flagged)" >&2
    exit 0
fi

# `gio set metadata::*` writes through GVFS' metadata daemon (db in
# ~/.local/share/gvfs-metadata/). At xrdp-session login the daemon may
# not be ready yet, in which case the write silently succeeds but the
# value never lands in the db and xfdesktop still sees no checksum.
# Wait briefly and verify after each write; retry once if needed.

echo "DBUS_SESSION_BUS_ADDRESS=${DBUS_SESSION_BUS_ADDRESS:-<unset>}"
echo "XDG_DATA_HOME=${XDG_DATA_HOME:-<unset>}"
sleep "${DEVMACHINE_TRUST_DELAY:-5}"

trust_one() {
    local f="$1"
    local sum read_sum
    sum=$(sha256sum "$f" | awk '{print $1}')

    for attempt in 1 2 3; do
        gio set -t string "$f" metadata::xfce-exe-checksum "$sum" 2>&1 || true
        gio set -t string "$f" metadata::trusted "true" 2>&1 || true
        read_sum=$(gio info -a metadata::xfce-exe-checksum "$f" 2>/dev/null \
            | sed -n 's/^.*metadata::xfce-exe-checksum: //p')
        if [ "$read_sum" = "$sum" ]; then
            echo "trusted $f ($sum)"
            return 0
        fi
        echo "attempt $attempt: gio set didn't stick on $f (saw '$read_sum')" >&2
        sleep 2
    done
    echo "GIVE UP on $f — gvfs-metadata likely not running" >&2
    return 1
}

shopt -s nullglob
ok=1
for f in "$HOME/Desktop"/*.desktop; do
    chmod +x "$f" 2>/dev/null || true
    trust_one "$f" || ok=0
done
shopt -u nullglob

if [ "$ok" -eq 1 ]; then
    echo "all done — removing autostart + self"
    rm -f "$AUTOSTART" "$SELF"
else
    echo "leaving autostart + self in place so the next session retries" >&2
fi
